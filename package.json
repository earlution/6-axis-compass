{
  "name": "six-axis-compass",
  "version": "2.4.6",
  "description": "A zero-dependency political compass mapping six axes: Cultural, Economic, Military, Sovereignty, Governance, and Class.",
  "main": "dist/index.html",
  "scripts": {
    "sync-actors": "node scripts/sync-actor-data.js",
    "build": "npm run sync-actors && node scripts/build.js",
    "dev": "npm run sync-actors && node scripts/build.js --watch",
    "generate-artifacts": "node scripts/generate-paper-artifacts.mjs",
    "generate-radar": "node scripts/generate-radar.mjs",
    "upload-osf": "node scripts/upload-to-osf.mjs",
    "upload-asset-to-osf": "node scripts/upload-asset-to-osf.mjs",
    "api": "node api/server.js",
    "test": "node tests/quiz.test.js && node tests/api.test.js"
  },
  "keywords": [
    "political-compass",
    "politics",
    "quiz",
    "radar-chart",
    "svg"
  ],
  "license": "MIT",
  "devDependencies": {
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5"
  }
}
